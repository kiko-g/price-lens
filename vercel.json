{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/scrape/scheduler",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/admin/analytics/compute-worker",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/admin/discovery?action=run&origin=all",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/admin/discovery/triage?batch=50",
      "schedule": "0 */6 * * *"
    }
  ]
}
